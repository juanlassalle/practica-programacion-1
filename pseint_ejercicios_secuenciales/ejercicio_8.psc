//Se requiere determinar el tiempo que tarda una persona en llegar de una ciudad
//a otra en bicicleta, considerando que lleva una velocidad constante
Algoritmo ejercicio_8
	Definir velocidad, distancia, tiempo Como Real
	
	Escribir "Ingresar la distancia entre las ciudades: "
	Leer distancia
	
	Escribir "Ingresar la velocidad: "
	Leer velocidad
	
	tiempo = distancia / velocidad
	
	Escribir "El tiempo que tardó la persona es: ",tiempo," minutos"
	
	
FinAlgoritmo
